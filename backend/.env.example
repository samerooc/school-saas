# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git
# ============================================================

# --- App ---
APP_NAME="SchoolSaaS"
APP_ENV="development"          # development | production
SECRET_KEY="change-this-to-random-64-char-string"
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- Database (Supabase free tier) ---
DATABASE_URL="postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres"
DATABASE_URL_SYNC="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# --- Redis (Redis Cloud free tier) ---
REDIS_URL="redis://default:password@redis-xxxxx.redis.cloud:6379"

# --- JWT (RS256) ---
# Generate with: openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH="./keys/private.pem"
JWT_PUBLIC_KEY_PATH="./keys/public.pem"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Email (Resend free: 3000 emails/month) ---
RESEND_API_KEY="re_xxxxxxxxxxxx"
FROM_EMAIL="noreply@yourschool.com"

# --- Cloudflare R2 (10GB free) ---
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="school-saas-files"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# --- YouTube Data API v3 (Free quota) ---
YOUTUBE_API_KEY="AIza..."
YOUTUBE_CLIENT_ID="xxx.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="GOCSPX-xxx"

# --- Cloudflare Stream (Free: 10min video) ---
CF_STREAM_TOKEN="your-cf-stream-token"
CF_ACCOUNT_ID="your-cf-account-id"
CF_STREAM_SIGNING_KEY="your-signing-key-id"
CF_STREAM_SIGNING_SECRET="your-signing-jwk-secret"

# --- Razorpay ---
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="your-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# --- Firebase FCM ---
FIREBASE_CREDENTIALS_PATH="./firebase-credentials.json"

# --- Encryption (for stream keys) ---
FERNET_KEY="generate-with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
